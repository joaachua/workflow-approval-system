{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "local": "NODE_ENV=localhost nodemon src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "staging": "NODE_ENV=staging node src/server.js",
    "prod": "NODE_ENV=production node src/server.js",
    "migrate": "knex migrate:latest --knexfile ./src/config/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile ./src/config/knexfile.js",
    "seed": "knex seed:run --knexfile ./src/config/knexfile.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:localdb": "NODE_ENV=localhost node tests/test-db.js",
    "test:devdb": "NODE_ENV=development node tests/test-db.js",
    "test:stagdb": "NODE_ENV=staging node tests/test-db.js",
    "test:proddb": "NODE_ENV=production node tests/test-db.js"
  },
  "keywords": [],
