  "description": "",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-flow": "^4.1.0",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.18.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
